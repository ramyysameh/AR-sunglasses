{% comment %}
  AR Try-On section for Shopify product pages.
  Host the built Vite app separately over HTTPS and point tryon_app_url at it.
{% endcomment %}

<div class="ar-tryon-section" data-ar-tryon-product="{{ product.id }}">
  <button class="ar-tryon-open" type="button">
    Try on
  </button>

  <dialog class="ar-tryon-dialog" aria-label="Sunglasses virtual try-on">
    <button class="ar-tryon-close" type="button" aria-label="Close try-on">&times;</button>
    <iframe
      class="ar-tryon-frame"
      allow="camera; fullscreen"
      src="{{ section.settings.tryon_app_url }}?provider=mediapipe&shopifyProductId={{ product.id }}&shopifyVariantId={{ product.selected_or_first_available_variant.id }}"
      loading="lazy"
    ></iframe>
  </dialog>
</div>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling
    const dialog = section.querySelector('.ar-tryon-dialog')
    const openButton = section.querySelector('.ar-tryon-open')
    const closeButton = section.querySelector('.ar-tryon-close')

    openButton.addEventListener('click', () => dialog.showModal())
    closeButton.addEventListener('click', () => dialog.close())
  })()
</script>

<style>
  .ar-tryon-open {
    min-height: 44px;
    padding: 0.75rem 1.2rem;
    border: 1px solid #111;
    border-radius: 4px;
    background: #111;
    color: #fff;
    font: inherit;
    cursor: pointer;
  }

  .ar-tryon-dialog {
    width: min(100vw, 520px);
    height: min(100dvh, 780px);
    padding: 0;
    border: 0;
    background: #000;
  }

  .ar-tryon-dialog::backdrop {
    background: rgba(0, 0, 0, 0.72);
  }

  .ar-tryon-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.72);
    color: #fff;
    font-size: 1.4rem;
    cursor: pointer;
  }

  .ar-tryon-frame {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

{% schema %}
{
  "name": "AR Try-On",
  "settings": [
    {
      "type": "url",
      "id": "tryon_app_url",
      "label": "Hosted try-on app URL"
    }
  ],
  "presets": [
    {
      "name": "AR Try-On"
    }
  ]
}
{% endschema %}
