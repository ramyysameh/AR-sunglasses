{% comment %}
  AR Try-On app block. Adds a "Try on" button to the product page that opens the
  hosted MediaPipe + Three.js try-on engine in a camera-permitted iframe. The engine
  reads ?shop= and ?productId= and fetches its calibrated config from the app.
{% endcomment %}

{% assign product_gid = 'gid://shopify/Product/' | append: block.settings.product.id %}

<div class="ar-tryon" {{ block.shopify_attributes }}>
  <button class="ar-tryon__open" type="button">
    {{ block.settings.button_label | default: 'Try on' }}
  </button>

  <dialog class="ar-tryon__dialog" aria-label="Sunglasses virtual try-on">
    <button class="ar-tryon__close" type="button" aria-label="Close try-on">&times;</button>
    {% if block.settings.engine_url != blank %}
      <iframe
        class="ar-tryon__frame"
        allow="camera; fullscreen"
        src="{{ block.settings.engine_url }}?shop={{ shop.permanent_domain | url_encode }}&productId={{ product_gid | url_encode }}"
        loading="lazy"
      ></iframe>
    {% else %}
      <p class="ar-tryon__missing">Set the try-on engine URL in the block settings.</p>
    {% endif %}
  </dialog>
</div>

<script>
  (() => {
    const root = document.currentScript.previousElementSibling
    const dialog = root.querySelector('.ar-tryon__dialog')
    root.querySelector('.ar-tryon__open').addEventListener('click', () => dialog.showModal())
    root.querySelector('.ar-tryon__close').addEventListener('click', () => dialog.close())
  })()
</script>

<style>
  .ar-tryon__open {
    min-height: 44px;
    padding: 0.75rem 1.2rem;
    border: 1px solid #111;
    border-radius: 4px;
    background: #111;
    color: #fff;
    font: inherit;
    cursor: pointer;
  }
  .ar-tryon__dialog {
    width: min(100vw, 520px);
    height: min(100dvh, 780px);
    padding: 0;
    border: 0;
    background: #000;
  }
  .ar-tryon__dialog::backdrop {
    background: rgba(0, 0, 0, 0.72);
  }
  .ar-tryon__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.72);
    color: #fff;
    font-size: 1.4rem;
    cursor: pointer;
  }
  .ar-tryon__frame {
    width: 100%;
    height: 100%;
    border: 0;
  }
  .ar-tryon__missing {
    color: #fff;
    padding: 1rem;
    font: inherit;
  }
</style>

{% schema %}
{
  "name": "AR Try-On",
  "target": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Product", "autofill": true },
    { "type": "text", "id": "engine_url", "label": "Try-on engine URL", "info": "Your app's URL + /tryon/index.html (e.g. https://localhost:3458/tryon/index.html in dev)." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Try on" }
  ]
}
{% endschema %}
