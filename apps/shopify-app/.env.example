# Shopify app — required environment variables.
# Copy to .env for local dev; set the same keys in the Vercel project for production.

# --- Shopify (Partner Dashboard > your app > Client credentials) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public HTTPS URL the app is served from. Replaces the "https://example.com"
# placeholder in shopify.app.toml, and must match the app URL + redirect URLs
# configured in the Partner Dashboard.
SHOPIFY_APP_URL=

# Access scopes. Keep in sync with shopify.app.toml. Reviewers reject scopes that
# aren't demonstrably used, so drop any that the app no longer needs.
SCOPES=write_products,write_metaobjects,write_metaobject_definitions

# Optional: only for stores served on a custom domain.
# SHOP_CUSTOM_DOMAIN=

# --- Database (Neon Postgres) ---
# Pooled connection string. Neon branches are handy here: point local dev at a
# dev branch and production at main, so they never share state.
DATABASE_URL=

# --- Object storage (AWS S3) ---
# Calibrated GLBs live here. Local disk is NOT usable in production: serverless
# filesystems are ephemeral, so anything written to disk is lost between
# invocations. See app/storage.server.js.
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Optional. Leave blank for AWS S3. Set it to point the same client at any
# S3-compatible store — e.g. Cloudflare R2 (https://<account>.r2.cloudflarestorage.com)
# if you later move for its zero egress fees. Backend swap = config, not code.
S3_ENDPOINT=
