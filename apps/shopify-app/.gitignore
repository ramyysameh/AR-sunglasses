# Built try-on engine (generated by `npm run build:engine` from repo root).
#
# Because this is ignored AND generated outside this package, it must be built
# during deploy or /tryon/index.html 404s in production -- which is exactly what
# happened between Phase 1 and 2026-07-24: the theme block iframes that URL, so
# the customer-facing try-on was dead on the live app while working locally.
# Vercel's build command (`npm run setup && npm run build`) never invoked the
# engine build, and the assets were not committed either.
#
# The `prebuild` script in package.json is what fixes that: npm runs it
# automatically before `build`, so the engine is generated and then copied into
# build/client/ by react-router build. Do not remove it.
/public/tryon
/prisma/dev.sqlite
/prisma/dev.sqlite-journal
database.sqlite

# Legacy dev-slice local model storage. Production stores calibrated GLBs in R2
# (app/storage.server.js); nothing writes here anymore.
/storage/

.env
.env.*
# ...but the committed template carries no secrets and must stay tracked.
!.env.example





/extensions/*/dist

# Ignore shopify files created during app dev
.shopify/*
.shopify.lock

# Hide files auto-generated by react router
.react-router/

# Vercel build output + local link metadata
.vercel/