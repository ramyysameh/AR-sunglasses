# Try-on engine (custom MediaPipe + Three.js pipeline)
VITE_TRYON_PROVIDER=mediapipe
VITE_TRYON_DEFAULT_SKU=sunglasses

# Camera capture resolution hints (the browser picks the closest supported mode).
VITE_TRYON_CAMERA_WIDTH=1280
VITE_TRYON_CAMERA_HEIGHT=720

# Shopify product/variant mappings per SKU (used to deep-link back to the PDP / cart).
VITE_SHOPIFY_PRODUCT_ID_SUNGLASSES=
VITE_SHOPIFY_VARIANT_ID_SUNGLASSES=
VITE_SHOPIFY_PRODUCT_ID_GRIPZ1=
VITE_SHOPIFY_VARIANT_ID_GRIPZ1=
